# Codex CLI override (если не на стандартном пути)
# Windows: %LOCALAPPDATA%\OpenAI\Codex\bin\codex.exe
# macOS:   ~/.local/bin/codex или /opt/homebrew/bin/codex
# Linux:   ~/.local/bin/codex или /usr/local/bin/codex
CODEX_CMD=

# Yandex API tokens — для marketing skills (yandex-* hub)
# Создать одно OAuth-приложение со скоупами Webmaster + Metrika + Direct: https://oauth.yandex.ru/client/new
YANDEX_OAUTH_TOKEN=
YANDEX_METRIKA_COUNTER_ID=
YANDEX_DIRECT_LOGIN=
YANDEX_WEBMASTER_USER_ID=
YANDEX_WEBMASTER_HOST_ID=

# Опционально: отдельные токены для Wordstat и Search (если используются)
YANDEX_WORDSTAT_OAUTH_TOKEN=
YANDEX_SEARCH_API_KEY=

# Опционально: OpenRouter API key для AI-visibility skill
OPENROUTER_API_KEY=

# Опционально: OpenAI API key (если не используется Codex CLI с ChatGPT subscription)
OPENAI_API_KEY=
