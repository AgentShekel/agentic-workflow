# === OAuth Token (Webmaster + Metrika + Direct) ===
# Create ONE app with all scopes at https://oauth.yandex.ru/client/new
YANDEX_OAUTH_TOKEN=

# === Metrika ===
# Counter is per-project — pass via --counter when running metrika scripts
# Set here only if you mostly work with one site:
# YANDEX_METRIKA_COUNTER=

# === XML Search ===
YANDEX_XML_USER=
YANDEX_XML_KEY=

# === Maps/Business Geosearch ===
YANDEX_MAPS_APIKEY=

# === Direct (optional) ===
# YANDEX_DIRECT_SANDBOX=false
# YANDEX_DIRECT_LOGIN=

# === OpenAI for Semantic Drift (optional) ===
# OPENAI_API_KEY=
