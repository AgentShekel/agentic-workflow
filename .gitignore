# Personal config never shipped
.env
*.env
!.env.example
!*/config/.env.example
config/.env
*/config/.env
**/config/.env

# Credentials
.credentials.json
mcp-needs-auth-cache.json
*credentials*
*-secret*
oauth-token*
auth-token*
api-token*

